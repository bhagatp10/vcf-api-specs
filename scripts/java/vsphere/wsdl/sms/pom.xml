<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <parent>
        <groupId>com.vmware.custom_sdk</groupId>
        <artifactId>vcf-custom-sdk-java</artifactId>
        <version>0.0.1</version>
        <relativePath>../../../pom.xml</relativePath>
    </parent>

    <artifactId>sms</artifactId>

    <properties>
        <sms.wsdl.root>${wsdl.root}/sms</sms.wsdl.root>
    </properties>

    <dependencies>
        <dependency>
            <groupId>${vcf.sdk.groupId}</groupId>
            <artifactId>vim25</artifactId>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.cxf</groupId>
                <artifactId>cxf-codegen-plugin</artifactId>
                <executions>
                    <execution>
                        <id>generate-bindings</id>
                        <configuration>
                            <wsdlRoot>${sms.wsdl.root}</wsdlRoot>
                            <includes>
                                <include>*.wsdl</include>
                            </includes>
                            <defaultOptions>
                                <bindingFiles>
                                    <bindingFile>${episode.file}</bindingFile>
                                </bindingFiles>
                                <extraargs>
                                    <extraarg>-suppress-generated-date</extraarg>
                                    <extraarg>-p</extraarg>
                                    <extraarg>urn:sms=${vcf.sdk.groupId}.sms</extraarg>
                                </extraargs>
                            </defaultOptions>
                            <wsdlOptions>
                                <wsdlOption>
                                    <wsdl>${sms.wsdl.root}/smsService.wsdl</wsdl>
                                    <wsdlLocation>smsService.wsdl</wsdlLocation>
                                    <extraargs>
                                        <extraarg>-p</extraarg>
                                        <extraarg>urn:smsService=${vcf.sdk.groupId}.sms</extraarg>
                                    </extraargs>
                                </wsdlOption>
                            </wsdlOptions>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <excludes>
                        <exclude>smsservice/**</exclude>
                    </excludes>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-source-plugin</artifactId>
                <executions>
                    <execution>
                        <id>attach-sources</id>
                        <configuration>
                            <excludes>
                                <exclude>smsservice/**</exclude>
                            </excludes>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>

        <resources>
            <resource>
                <directory>${sms.wsdl.root}</directory>
            </resource>
        </resources>
    </build>

</project>